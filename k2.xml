<?xml version="1.0" encoding="utf-8"?>
<extension type="component" method="upgrade">
    <name>COM_K2</name>
    <author>Russell English, Storm Web Design Ltd</author>
    <creationDate>2026-03-19</creationDate>
    <copyright>Copyright (C) 2026 Storm Web Design Ltd. All rights reserved.</copyright>
    <license>GNU General Public License version 2 or later; see LICENSE.txt</license>
    <authorEmail>info@stormwebdesign.co.uk</authorEmail>
    <authorUrl>https://stormwebdesign.co.uk</authorUrl>
    <version>3.0.1</version>
    <description>COM_K2_DESCRIPTION</description>
    <namespace path="src">Joomla\Component\K2</namespace>
    <scriptfile>script.php</scriptfile>

    <install>
        <sql>
            <file driver="mysql" charset="utf8mb4">sql/install.mysql.sql</file>
        </sql>
    </install>
    <uninstall>
        <sql>
            <file driver="mysql" charset="utf8mb4">sql/uninstall.mysql.sql</file>
        </sql>
    </uninstall>
    <update>
        <schemas>
            <schemapath type="mysql">sql/updates/mysql</schemapath>
        </schemas>
    </update>

    <files folder="components/com_k2">
        <folder>controllers</folder>
        <folder>css</folder>
        <folder>forms</folder>
        <folder>helpers</folder>
        <folder>images</folder>
        <folder>models</folder>
        <folder>src</folder>
        <folder>templates</folder>
        <folder>views</folder>
        <filename>k2.php</filename>
        <filename>router.php</filename>
    </files>

    <media destination="k2" folder="media/k2">
        <folder>assets</folder>
        <folder>attachments</folder>
        <folder>categories</folder>
        <folder>galleries</folder>
        <folder>items</folder>
        <folder>users</folder>
        <folder>videos</folder>
    </media>

    <languages folder="language">
        <language tag="en-GB">en-GB/en-GB.com_k2.ini</language>
    </languages>

    <administration>
        <menu img="class:k2">COM_K2</menu>
        <submenu>
            <menu view="items" link="option=com_k2&amp;view=items">COM_K2_ITEMS</menu>
            <menu view="categories" link="option=com_k2&amp;view=categories">COM_K2_CATEGORIES</menu>
            <menu view="tags" link="option=com_k2&amp;view=tags">COM_K2_TAGS</menu>
            <menu view="comments" link="option=com_k2&amp;view=comments">COM_K2_COMMENTS</menu>
            <menu view="users" link="option=com_k2&amp;view=users">COM_K2_USERS</menu>
            <menu view="usergroups" link="option=com_k2&amp;view=usergroups">COM_K2_USER_GROUPS</menu>
            <menu view="extrafields" link="option=com_k2&amp;view=extrafields">COM_K2_EXTRA_FIELDS</menu>
            <menu view="extrafieldsgroups" link="option=com_k2&amp;view=extrafieldsgroups">COM_K2_EXTRA_FIELD_GROUPS</menu>
            <menu view="media" link="option=com_k2&amp;view=media">COM_K2_MEDIA_MANAGER</menu>
        </submenu>
        <files folder="administrator/components/com_k2">
            <folder>controllers</folder>
            <folder>elements</folder>
            <folder>forms</folder>
            <folder>helpers</folder>
            <folder>jupgrade</folder>
            <folder>lib</folder>
            <folder>models</folder>
            <folder>services</folder>
            <folder>sql</folder>
            <folder>src</folder>
            <folder>tables</folder>
            <folder>views</folder>
            <filename>access.xml</filename>
            <filename>config.xml</filename>
            <filename>k2.php</filename>
        </files>
        <languages folder="administrator/language">
            <language tag="en-GB">en-GB/en-GB.com_k2.ini</language>
            <language tag="en-GB">en-GB/en-GB.com_k2.sys.ini</language>
            <language tag="en-GB">en-GB/en-GB.com_k2.menu.ini</language>
        </languages>
    </administration>

    <updateservers>
        <server type="extension" priority="1" name="K2">https://updates.getk2.org/update.xml</server>
    </updateservers>
</extension>
