<?xml version="1.0" encoding="utf-8"?>
<extension type="module" client="site" method="upgrade">
    <name>mod_k2_content</name>
    <author>Russell English - Storm Web Design</author>
    <creationDate>2026</creationDate>
    <copyright>Copyright (C) 2026 Storm Web Design Ltd. All rights reserved.</copyright>
    <license>GNU/GPL v2 or later</license>
    <authorEmail>support@stormwebdesign.co.uk</authorEmail>
    <authorUrl>https://stormwebdesign.co.uk</authorUrl>
    <version>3.0.0</version>
    <description>K2_MOD_K2_CONTENT_DESCRIPTION</description>
    <namespace path="src">Joomla\Module\K2Content</namespace>
    <files>
        <folder>services</folder>
        <folder>src</folder>
        <folder>tmpl</folder>
    </files>
    <languages>
        <language tag="en-GB">language/en-GB/mod_k2_content.ini</language>
        <language tag="en-GB">language/en-GB/mod_k2_content.sys.ini</language>
    </languages>
    <config>
        <fields name="params">
            <fieldset name="basic" label="COM_MODULES_BASIC_FIELDSET_LABEL">
                <field
                    name="source"
                    type="list"
                    label="K2_SOURCE"
                    default="filter"
                >
                    <option value="filter">K2_RETRIEVE_ITEMS_FROM_CATEGORIES</option>
                    <option value="specific">K2_SELECT_SPECIFIC_ITEMS</option>
                </field>
                <field
                    name="items"
                    type="text"
                    label="K2_ITEM_SELECTOR"
                    description="K2_ENTER_ITEM_IDS_COMMA_SEPARATED"
                    showon="source:specific"
                />
                <field
                    name="category_id"
                    type="sql"
                    label="K2_SELECT_ONE_OR_MORE_CATEGORIES"
                    query="SELECT id AS value, name AS text FROM #__k2_categories WHERE trash = 0 ORDER BY name"
                    key_field="value"
                    value_field="text"
                    multiple="true"
                    showon="source:filter"
                />
                <field
                    name="getChildren"
                    type="radio"
                    label="K2_FETCH_ITEMS_FROM_CHILDREN_CATEGORIES"
                    layout="joomla.form.field.radio.switcher"
                    default="0"
                    showon="source:filter"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
                <field
                    name="itemCount"
                    type="number"
                    label="K2_ITEM_COUNT"
                    default="5"
                    min="1"
                />
                <field
                    name="itemsOrdering"
                    type="list"
                    label="K2_ITEM_ORDERING"
                    default="rdate"
                >
                    <option value="date">K2_OLDEST_FIRST</option>
                    <option value="rdate">K2_MOST_RECENT_FIRST</option>
                    <option value="publishUp">K2_RECENTLY_PUBLISHED</option>
                    <option value="alpha">K2_TITLE_ALPHABETICAL</option>
                    <option value="ralpha">K2_TITLE_REVERSEALPHABETICAL</option>
                    <option value="order">K2_ORDERING</option>
                    <option value="rorder">K2_ORDERING_REVERSE</option>
                    <option value="hits">K2_MOST_POPULAR</option>
                    <option value="modified">K2_LATEST_MODIFIED</option>
                    <option value="rand">K2_RANDOM_ORDERING</option>
                </field>
                <field
                    name="FeaturedItems"
                    type="list"
                    label="K2_FEATURED_ITEMS"
                    default="1"
                >
                    <option value="0">K2_HIDE</option>
                    <option value="1">K2_SHOW</option>
                    <option value="2">K2_SHOW_ONLY_FEATURED_ITEMS</option>
                </field>
            </fieldset>
            <fieldset name="display" label="K2_ITEM_VIEW_OPTIONS">
                <field
                    name="itemTitle"
                    type="radio"
                    label="K2_TITLE"
                    layout="joomla.form.field.radio.switcher"
                    default="1"
                >
                    <option value="0">K2_HIDE</option>
                    <option value="1">K2_SHOW</option>
                </field>
                <field
                    name="itemImage"
                    type="radio"
                    label="K2_IMAGE"
                    layout="joomla.form.field.radio.switcher"
                    default="1"
                >
                    <option value="0">K2_HIDE</option>
                    <option value="1">K2_SHOW</option>
                </field>
                <field
                    name="itemImgSize"
                    type="list"
                    label="K2_IMAGE_SIZE"
                    default="Small"
                    showon="itemImage:1"
                >
                    <option value="XSmall">K2_XSMALL</option>
                    <option value="Small">K2_SMALL</option>
                    <option value="Medium">K2_MEDIUM</option>
                    <option value="Large">K2_LARGE</option>
                    <option value="XLarge">K2_XLARGE</option>
                </field>
                <field
                    name="itemIntroText"
                    type="radio"
                    label="K2_INTROTEXT"
                    layout="joomla.form.field.radio.switcher"
                    default="1"
                >
                    <option value="0">K2_HIDE</option>
                    <option value="1">K2_SHOW</option>
                </field>
                <field
                    name="itemIntroTextWordLimit"
                    type="number"
                    label="K2_INTROTEXT_WORD_LIMIT"
                    default="50"
                    showon="itemIntroText:1"
                />
                <field
                    name="itemAuthor"
                    type="radio"
                    label="K2_USER_AUTHOR"
                    layout="joomla.form.field.radio.switcher"
                    default="1"
                >
                    <option value="0">K2_HIDE</option>
                    <option value="1">K2_SHOW</option>
                </field>
                <field
                    name="itemCategory"
                    type="radio"
                    label="K2_CATEGORY"
                    layout="joomla.form.field.radio.switcher"
                    default="1"
                >
                    <option value="0">K2_HIDE</option>
                    <option value="1">K2_SHOW</option>
                </field>
                <field
                    name="itemDateCreated"
                    type="radio"
                    label="K2_CREATED_DATE_AND_TIME"
                    layout="joomla.form.field.radio.switcher"
                    default="1"
                >
                    <option value="0">K2_HIDE</option>
                    <option value="1">K2_SHOW</option>
                </field>
                <field
                    name="itemHits"
                    type="radio"
                    label="K2_HITS"
                    layout="joomla.form.field.radio.switcher"
                    default="0"
                >
                    <option value="0">K2_HIDE</option>
                    <option value="1">K2_SHOW</option>
                </field>
                <field
                    name="itemTags"
                    type="radio"
                    label="K2_TAGS"
                    layout="joomla.form.field.radio.switcher"
                    default="0"
                >
                    <option value="0">K2_HIDE</option>
                    <option value="1">K2_SHOW</option>
                </field>
                <field
                    name="itemReadMore"
                    type="radio"
                    label="K2_READ_MORE_LINK"
                    layout="joomla.form.field.radio.switcher"
                    default="1"
                >
                    <option value="0">K2_HIDE</option>
                    <option value="1">K2_SHOW</option>
                </field>
            </fieldset>
            <fieldset name="advanced" label="COM_MODULES_ADVANCED_FIELDSET_LABEL">
                <field
                    name="layout"
                    type="modulelayout"
                    label="JFIELD_ALT_LAYOUT_LABEL"
                    class="form-select"
                />
                <field
                    name="moduleclass_sfx"
                    type="textarea"
                    label="COM_MODULES_FIELD_MODULECLASS_SFX_LABEL"
                    rows="3"
                />
                <field
                    name="K2Plugins"
                    type="radio"
                    label="K2_ENABLE_K2_PLUGINS"
                    layout="joomla.form.field.radio.switcher"
                    default="1"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
                <field
                    name="JPlugins"
                    type="radio"
                    label="K2_ENABLE_JOOMLA_CONTENT_PLUGINS"
                    layout="joomla.form.field.radio.switcher"
                    default="1"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
            </fieldset>
        </fields>
    </config>
</extension>
