<?xml version="1.0" encoding="utf-8"?>
<form>
    <fieldset name="basic" label="COM_K2_BASIC">
        <field
            name="id"
            type="hidden"
        />
        <field
            name="name"
            type="text"
            label="JGLOBAL_TITLE"
            required="true"
            size="40"
            class="form-control"
        />
        <field
            name="published"
            type="list"
            label="JSTATUS"
            default="1"
            class="form-select"
        >
            <option value="1">JPUBLISHED</option>
            <option value="0">JUNPUBLISHED</option>
        </field>
        <field
            name="description"
            type="textarea"
            label="JGLOBAL_DESCRIPTION"
            rows="4"
            class="form-control"
        />
    </fieldset>
</form>
