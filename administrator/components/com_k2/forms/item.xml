<?xml version="1.0" encoding="utf-8"?>
<form>
    <fieldset name="basic" label="COM_K2_BASIC">
        <field
            name="id"
            type="hidden"
        />
        <field
            name="title"
            type="text"
            label="JGLOBAL_TITLE"
            required="true"
            size="40"
            class="form-control"
        />
        <field
            name="alias"
            type="text"
            label="JFIELD_ALIAS_LABEL"
            hint="JFIELD_ALIAS_PLACEHOLDER"
            size="40"
            class="form-control"
        />
        <field
            name="catid"
            type="sql"
            label="JCATEGORY"
            required="true"
            query="SELECT id AS value, name AS text FROM #__k2_categories WHERE trash = 0 ORDER BY name"
            key_field="value"
            value_field="text"
            class="form-select"
        />
        <field
            name="published"
            type="list"
            label="JSTATUS"
            default="1"
            class="form-select"
        >
            <option value="1">JPUBLISHED</option>
            <option value="0">JUNPUBLISHED</option>
        </field>
        <field
            name="featured"
            type="list"
            label="JFEATURED"
            default="0"
            class="form-select"
        >
            <option value="0">JNO</option>
            <option value="1">JYES</option>
        </field>
        <field
            name="access"
            type="accesslevel"
            label="JFIELD_ACCESS_LABEL"
            default="1"
            class="form-select"
        />
        <field
            name="language"
            type="contentlanguage"
            label="JFIELD_LANGUAGE_LABEL"
            class="form-select"
        >
            <option value="*">JALL</option>
        </field>
    </fieldset>
    <fieldset name="content" label="COM_K2_CONTENT">
        <field
            name="introtext"
            type="editor"
            label="COM_K2_INTRO_TEXT"
            filter="safehtml"
            buttons="true"
        />
        <field
            name="fulltext"
            type="editor"
            label="COM_K2_FULL_TEXT"
            filter="safehtml"
            buttons="true"
        />
    </fieldset>
    <fieldset name="publishing" label="JGLOBAL_FIELDSET_PUBLISHING">
        <field
            name="created"
            type="calendar"
            label="JGLOBAL_FIELD_CREATED_LABEL"
            translateformat="true"
            showtime="true"
            class="form-control"
        />
        <field
            name="created_by"
            type="user"
            label="JGLOBAL_FIELD_CREATED_BY_LABEL"
            class="form-control"
        />
        <field
            name="created_by_alias"
            type="text"
            label="JGLOBAL_FIELD_CREATED_BY_ALIAS_LABEL"
            size="20"
            class="form-control"
        />
        <field
            name="modified"
            type="calendar"
            label="JGLOBAL_FIELD_MODIFIED_LABEL"
            translateformat="true"
            showtime="true"
            readonly="true"
            class="form-control"
        />
        <field
            name="modified_by"
            type="user"
            label="JGLOBAL_FIELD_MODIFIED_BY_LABEL"
            readonly="true"
            class="form-control"
        />
        <field
            name="publish_up"
            type="calendar"
            label="JGLOBAL_FIELD_PUBLISH_UP_LABEL"
            translateformat="true"
            showtime="true"
            class="form-control"
        />
        <field
            name="publish_down"
            type="calendar"
            label="JGLOBAL_FIELD_PUBLISH_DOWN_LABEL"
            translateformat="true"
            showtime="true"
            class="form-control"
        />
        <field
            name="hits"
            type="number"
            label="JGLOBAL_HITS"
            readonly="true"
            default="0"
            class="form-control"
        />
    </fieldset>
    <fieldset name="images" label="COM_K2_IMAGES">
        <field
            name="image"
            type="file"
            label="COM_K2_ITEM_IMAGE"
            accept="image/*"
            class="form-control"
        />
        <field
            name="image_caption"
            type="text"
            label="COM_K2_IMAGE_CAPTION"
            size="40"
            class="form-control"
        />
        <field
            name="image_credits"
            type="text"
            label="COM_K2_IMAGE_CREDITS"
            size="40"
            class="form-control"
        />
    </fieldset>
    <fieldset name="video" label="COM_K2_VIDEO">
        <field
            name="video"
            type="textarea"
            label="COM_K2_VIDEO_EMBED"
            rows="4"
            cols="40"
            class="form-control"
        />
        <field
            name="video_caption"
            type="text"
            label="COM_K2_VIDEO_CAPTION"
            size="40"
            class="form-control"
        />
        <field
            name="video_credits"
            type="text"
            label="COM_K2_VIDEO_CREDITS"
            size="40"
            class="form-control"
        />
    </fieldset>
    <fieldset name="metadata" label="JGLOBAL_FIELDSET_METADATA_OPTIONS">
        <field
            name="metadesc"
            type="textarea"
            label="JFIELD_META_DESCRIPTION_LABEL"
            rows="3"
            class="form-control"
        />
        <field
            name="metakey"
            type="textarea"
            label="JFIELD_META_KEYWORDS_LABEL"
            rows="3"
            class="form-control"
        />
        <field
            name="metadata"
            type="subform"
            label="JGLOBAL_FIELDSET_METADATA_OPTIONS"
            hiddenLabel="true"
            formsource="administrator/components/com_k2/forms/item_metadata.xml"
            multiple="false"
        />
    </fieldset>
</form>
